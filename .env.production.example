# ============================================
# VARIÁVEIS DE AMBIENTE - PRODUÇÃO
# ============================================
# Copie este arquivo para .env.production e preencha com seus valores reais
# NUNCA commitar o .env.production!
# Use este arquivo APENAS como referência para configurar na Vercel/Netlify

# ============================================
# SITE (PRODUÇÃO)
# ============================================
# URL real do seu site em produção
NEXT_PUBLIC_SITE_URL=https://meu-portfolio.vercel.app

# ============================================
# CONTATO (VALORES REAIS EM PRODUÇÃO)
# ============================================
# Email para formulário de contato (seu email REAL em produção)
CONTACT_EMAIL=seu-email-real-em-producao@exemplo.com
CONTACT_EMAIL_SECRET=seu-email-secreto-em-producao@exemplo.com

# ============================================
# SEGURANÇA - Rate Limiting (Produção)
# ============================================
# Em produção, valores mais restritivos
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30  # Mais restrito que desenvolvimento

# ============================================
# API (Produção - URLs reais)
# ============================================
API_KEY=sua-chave-api-real-de-producao
API_URL=https://api.real.com/v1

# ============================================
# RECAPTCHA (Produção - Chaves REAIS)
# ============================================
# Chaves REAIS do Google reCAPTCHA (não as de teste)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6LcFxgUrAAAAAChB12345XYZ
RECAPTCHA_SECRET_KEY=6LcFxgUrAAAAABcdef67890ABC

# ============================================
# GOOGLE ANALYTICS (Produção - ID REAL)
# ============================================
# Seu ID real do Google Analytics 4
NEXT_PUBLIC_GA_ID=G-ABCDEFGHIJ

# ============================================
# REDES SOCIAIS (Links REAIS)
# ============================================
NEXT_PUBLIC_GITHUB_URL=https://github.com/seu-usuario-real
NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/in/seu-usuario-real

# ============================================
# EMAIL SERVICE (Produção - Credenciais REAIS)
# ============================================
# Credenciais reais do serviço de email (ex: Resend, EmailJS, SendGrid)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_real_abc123
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_real_xyz789
NEXT_PUBLIC_EMAILJS_USER_ID=user_real_123456

# ============================================
# NOTAS IMPORTANTES - PRODUÇÃO
# ============================================
# ⚠️ NUNCA commitar este arquivo com valores reais!
# ✅ Configure estas variáveis diretamente no dashboard da Vercel/Netlify
# 🔒 Em produção, NUNCA exponha chaves secretas no cliente
# 📝 Use variáveis com NEXT_PUBLIC_ apenas quando necessário
# 🚀 A Vercel permite configurar variáveis por ambiente (development/preview/production)