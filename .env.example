# ============================================
# VARIÁVEIS DE AMBIENTE - PORTFÓLIO
# ============================================
# Copie este arquivo para .env.local e preencha com seus valores reais
# NUNCA commitar o .env.local!

# ============================================
# SITE
# ============================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================
# CONTATO
# ============================================
# Email para formulário de contato (coloque seu email real no .env.local)
CONTACT_EMAIL=seu-email@exemplo.com
CONTACT_EMAIL_SECRET=seu-email-real@exemplo.com

# ============================================
# SEGURANÇA - Rate Limiting
# ============================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# ============================================
# API (exemplo - se usar alguma)
# ============================================
API_KEY=sua-chave-api-aqui-12345
API_URL=https://api.exemplo.com/v1

# ============================================
# RECAPTCHA (opcional - para proteção de formulário)
# ============================================
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6LeIxAcTAAAAAJcZVRqyHh71UMIEGNQ_MXjiZKhI
RECAPTCHA_SECRET_KEY=6LeIxAcTAAAAAGG-vFI1TnRWxMZNFuojJ4WifJWe

# ============================================
# GOOGLE ANALYTICS (opcional)
# ============================================
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ============================================
# REDES SOCIAIS (seus links - opcional)
# ============================================
NEXT_PUBLIC_GITHUB_URL=https://github.com/seu-usuario
NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/in/seu-usuario

# ============================================
# EMAIL SERVICE (exemplo - se usar EmailJS)
# ============================================
# NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_abc123
# NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_xyz789
# NEXT_PUBLIC_EMAILJS_USER_ID=user_123456

# ============================================
# NOTAS IMPORTANTES
# ============================================
# ✅ Variáveis com NEXT_PUBLIC_ → seguras para o cliente
# 🔒 Variáveis SEM NEXT_PUBLIC_ → apenas servidor (mais seguras)
# ⚠️ Nunca commitar chaves reais ou senhas
# 📝 Use .env.local para desenvolvimento com valores reais